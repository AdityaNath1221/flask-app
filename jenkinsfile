pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "adityanath1221/flask-app-demo"
    }

    stages {

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${DOCKER_IMAGE}:latest")
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'dockerhub-creds') {
                        docker.image("${DOCKER_IMAGE}:latest").push()
                    }
                }
            }
        }

        stage('Deploy to Kubernetes Server') {
            steps {
                sh '''
                ssh -i /var/lib/jenkins/.ssh/id_rsa \
                -o StrictHostKeyChecking=no \
                vagrant@192.168.56.15 "

                    pkill kubectl || true &&

                    rm -rf flask-app &&

                    git clone https://github.com/AdityaNath1221/flask-app.git &&

                    kubectl apply -f /home/vagrant/flask-app/deployment.yaml &&

                    kubectl apply -f /home/vagrant/flask-app/service.yaml &&

                    setsid kubectl port-forward service/flask-devops-service \
                    5000:5000 --address=0.0.0.0 \
                    > /dev/null 2>&1 < /dev/null &

                    exit
                "
                '''
            }
        }
    }
}